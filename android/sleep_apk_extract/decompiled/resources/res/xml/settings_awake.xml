<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:robobunny="http://robobunny.com" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:title="@string/settings">
    <PreferenceCategory
        android:layout="@layout/category_empty"
        android:key="settings_category_awake">
        <com.urbandroid.sleep.gui.SeekBarCardPreference
            android:icon="@drawable/ic_feature_movement"
            android:layout="@layout/preference_card_seek_bar"
            android:max="3"
            android:title="@string/non_deep_sleep_sensitivity_title"
            android:key="awake_activity_sensitivity"
            android:defaultValue="2"
            app:seekBarStringArray="@array/sensitivity_array"
            robobunny:min="0"
            robobunny:unitsLeft=""
            robobunny:unitsRight=""/>
        <com.urbandroid.sleep.gui.SeekBarCardPreference
            android:icon="@drawable/ic_lullaby_heart"
            android:layout="@layout/preference_card_seek_bar"
            android:max="3"
            android:title="@string/hr"
            android:key="awake_hr_sensitivity"
            android:defaultValue="2"
            app:seekBarStringArray="@array/sensitivity_array"
            robobunny:min="0"
            robobunny:unitsLeft=""
            robobunny:unitsRight=""/>
        <com.urbandroid.sleep.gui.SeekBarCardPreference
            android:icon="@drawable/ic_feature_smartlight"
            android:layout="@layout/preference_card_seek_bar"
            android:max="3"
            android:title="@string/light"
            android:key="awake_light_sensitivity"
            android:defaultValue="2"
            app:seekBarStringArray="@array/sensitivity_array"
            robobunny:min="0"
            robobunny:unitsLeft=""
            robobunny:unitsRight=""/>
        <com.urbandroid.sleep.gui.SeekBarCardPreference
            android:icon="@drawable/ic_feature_sound_recognition"
            android:layout="@layout/preference_card_seek_bar"
            android:max="3"
            android:title="@string/sound_recognition"
            android:key="awake_sound_sensitivity"
            android:defaultValue="2"
            app:seekBarStringArray="@array/sensitivity_array"
            robobunny:min="0"
            robobunny:unitsLeft=""
            robobunny:unitsRight=""/>
        <com.urbandroid.sleep.gui.SeekBarCardPreference
            android:icon="@drawable/ic_captcha_smilecaptcha"
            android:layout="@layout/preference_card_seek_bar"
            android:max="3"
            android:title="@string/awake_detection_when_using_phone"
            android:key="awake_phone_use_sensitivity"
            android:defaultValue="0"
            app:seekBarStringArray="@array/sensitivity_array"
            robobunny:min="0"
            robobunny:unitsLeft=""
            robobunny:unitsRight=""/>
        <CheckBoxPreference
            android:icon="@drawable/ic_feature_snooze"
            android:layout="@layout/preference_card"
            android:title="@string/alarm_alert_snooze_text"
            android:key="key_awake_detection_snooze"
            android:widgetLayout="@layout/preference_switch_widget"
            android:defaultValue="true"/>
    </PreferenceCategory>
    <PreferenceCategory
        android:layout="@layout/category"
        android:title="@string/menu_pause_tracking"
        android:key="settings_category_pause">
        <com.urbandroid.sleep.gui.MaterialDialogListPreference
            android:icon="@drawable/ic_action_pause"
            android:entries="@array/delay_tracking_entries"
            android:layout="@layout/preference"
            android:title="@string/delay_tracking_title"
            android:key="delay_tracking"
            android:summary="@string/delay_tracking_summary"
            android:defaultValue="0"
            android:entryValues="@array/delay_tracking_values"/>
        <CheckBoxPreference
            android:icon="@drawable/ic_action_screen_rotation"
            android:layout="@layout/preference"
            android:title="@string/flip_to_pause"
            android:key="flip_to_pause"
            android:widgetLayout="@layout/preference_switch_widget"
            android:defaultValue="false"/>
    </PreferenceCategory>
    <Preference
        android:persistent="false"
        android:layout="@layout/preference"
        android:key="empty1"/>
    <Preference
        android:persistent="false"
        android:layout="@layout/preference"
        android:key="empty2"/>
</PreferenceScreen>
