<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:robobunny="http://robobunny.com" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:title="@string/settings">
    <Preference
        android:persistent="false"
        android:layout="@layout/preference_summary"
        android:key="smart_expl"
        android:summary="@string/smart_period_summary"/>
    <PreferenceCategory
        android:layout="@layout/category_empty"
        android:key="settings_category_smart">
        <com.urbandroid.sleep.gui.MaterialDialogListPreference
            android:icon="@drawable/ic_feature_smart_period"
            android:entries="@array/non_deep_sleep_window_entries"
            android:layout="@layout/preference_card"
            android:title="@string/non_deep_sleep_window_title"
            android:key="non_deep_sleep_window"
            android:summary="@string/non_deep_sleep_window_summary"
            android:defaultValue="30"
            android:dialogTitle="@string/non_deep_sleep_window_title"
            android:entryValues="@array/non_deep_sleep_window_values"/>
        <com.urbandroid.sleep.gui.MaterialDialogListPreference
            android:icon="@drawable/ic_action_snooze"
            android:entries="@array/non_deep_sleep_window_entries"
            android:layout="@layout/preference"
            android:title="@string/non_deep_sleep_window_nap_title"
            android:key="non_deep_sleep_window_nap"
            android:summary="@string/non_deep_sleep_window_nap_summary"
            android:defaultValue="5"
            android:dialogTitle="@string/non_deep_sleep_window_title"
            android:entryValues="@array/non_deep_sleep_window_values"/>
    </PreferenceCategory>
    <com.urbandroid.sleep.gui.pref.LamerPreferenceCategory
        android:layout="@layout/category"
        android:title="@string/settings_category_advanced"
        android:key="settings_category_advanced"
        show="0">
        <com.urbandroid.sleep.gui.SeekBarPreference
            android:icon="@drawable/ic_walk"
            android:layout="@layout/preference"
            android:max="3"
            android:title="@string/non_deep_sleep_sensitivity_title"
            android:key="non_deep_sleep_sensitivity_checks_new"
            android:defaultValue="1"
            app:maxString="@string/low_sensitivity"
            app:minString="@string/high_sensitivity"
            app:seekBarStringArray="@array/sensitivity_array_smart_wake"
            robobunny:min="0"
            robobunny:unitsLeft=""
            robobunny:unitsRight=""/>
        <CheckBoxPreference
            android:icon="@drawable/empty_ab"
            android:layout="@layout/preference"
            android:title="@string/early_ideal_title"
            android:key="act_on_target_sleep_time2"
            android:summary="@string/early_ideal_summary"
            android:widgetLayout="@layout/preference_switch_widget"
            android:defaultValue="false"/>
        <Preference
            android:icon="@drawable/ic_menu_down"
            android:layout="@layout/preference_more"
            android:title="Advance settings"/>
    </com.urbandroid.sleep.gui.pref.LamerPreferenceCategory>
    <Preference
        android:persistent="false"
        android:layout="@layout/preference"
        android:key="empty1"/>
    <Preference
        android:persistent="false"
        android:layout="@layout/preference"
        android:key="empty2"/>
</PreferenceScreen>
