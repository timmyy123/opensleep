<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:robobunny="http://robobunny.com" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:title="@string/set_alarm">
    <com.urbandroid.sleep.gui.DefaultValueListPreference
        android:icon="@drawable/ic_feature_bedtime_notification"
        android:persistent="false"
        android:entries="@array/target_sleep_time_notify_entries"
        android:layout="@layout/preference_card"
        android:title="@string/target_sleep_time_notify_title"
        android:key="alarm_target_sleep_time_notify_before"
        android:entryValues="@array/target_sleep_time_notify_values"/>
    <Preference
        android:enabled="false"
        android:layout="@layout/preference_timeline_segment"
        android:key="timeline_segment_bedtime"
        android:summary="@string/bedtime_notification_expl"/>
    <Preference
        android:icon="@drawable/ic_feature_bedtime"
        android:enabled="false"
        android:layout="@layout/preference_timeline_point"
        android:title="@string/time_to_bed_title"
        android:key="timeline_bedtime"/>
    <Preference
        android:enabled="false"
        android:layout="@layout/preference_timeline_segment"
        android:key="timeline_segment_sleep"
        android:summary="@string/bedtime_expl"/>
    <com.urbandroid.sleep.gui.SeekBarCardPreference
        android:icon="@drawable/ic_feature_target"
        android:persistent="false"
        android:layout="@layout/preference_card_seek_bar"
        android:max="840"
        android:title="@string/target_sleep_time_per_alarm"
        android:key="target_sleep_minutes"
        robobunny:interval="10"
        robobunny:min="20"
        robobunny:unitsLeft=""
        robobunny:unitsRight=""/>
    <com.urbandroid.sleep.gui.ButtonPreference
        android:icon="@drawable/empty_ab"
        android:persistent="false"
        android:layout="@layout/preference_button_under_card"
        android:title="@string/reset"
        android:key="target_sleep_default"
        android:summary="@string/default_ringtone_name"/>
    <Preference
        android:enabled="false"
        android:layout="@layout/preference_timeline_segment"
        android:key="timeline_segment_wake_up"
        android:summary="@string/settings_category_sleep"/>
    <Preference
        android:icon="@drawable/ic_lullaby_clock"
        android:enabled="false"
        android:layout="@layout/preference_timeline_point"
        android:title="@string/default_label"
        android:key="timeline_alarm"/>
    <Preference
        android:enabled="false"
        android:layout="@layout/preference"
        android:title=""
        android:key="timeline_segment4"/>
    <Preference
        android:persistent="false"
        android:layout="@layout/preference"
        android:key="empty1"/>
    <Preference
        android:persistent="false"
        android:layout="@layout/preference"
        android:key="empty2"/>
    <Preference
        android:persistent="false"
        android:layout="@layout/preference"
        android:key="empty3"/>
    <Preference
        android:persistent="false"
        android:layout="@layout/preference"
        android:key="empty4"/>
</PreferenceScreen>
