<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:robobunny="http://robobunny.com" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:title="@string/alarm_alert_snooze_text">
    <com.urbandroid.sleep.gui.DefaultValueListPreference
        android:icon="@drawable/ic_feature_snooze"
        android:persistent="false"
        android:entries="@array/snooze_duration_entries"
        android:layout="@layout/preference_card"
        android:title="@string/snooze_duration_title"
        android:key="alarm_snooze_duration"
        android:dialogTitle="@string/snooze_duration_title"
        android:entryValues="@array/snooze_duration_values"/>
    <com.urbandroid.sleep.gui.DefaultValueListPreference
        android:icon="@drawable/ic_action_repeat"
        android:persistent="false"
        android:entries="@array/snooze_limit_entries"
        android:layout="@layout/preference"
        android:title="@string/snooze_limit_title"
        android:key="alarm_snooze_limit"
        android:dialogTitle="@string/snooze_limit_title"
        android:entryValues="@array/snooze_limit_values"/>
