        android:persistent="false"
        android:layout="@layout/preference"
        android:key="empty1"/>
    <Preference
        android:persistent="false"
        android:layout="@layout/preference"
        android:key="empty2"/>
    <Preference
        android:persistent="false"
        android:layout="@layout/preference"
        android:key="empty3"/>
    <Preference
        android:persistent="false"
        android:layout="@layout/preference"
        android:key="empty4"/>
