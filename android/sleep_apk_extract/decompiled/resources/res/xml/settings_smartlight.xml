<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:robobunny="http://robobunny.com" xmlns:android="http://schemas.android.com/apk/res/android" android:title="@string/settings">
    <PreferenceCategory
        android:layout="@layout/category_empty"
        android:key="settings_category_smartlight">
        <com.urbandroid.sleep.gui.EnablePreference
            android:layout="@layout/preference_enable"
            android:key="smartlight"
            android:widgetLayout="@layout/preference_switch_widget"
            android:defaultValue="false"
            android:summaryOn="@string/enabled"
            android:summaryOff="@string/disabled"/>
    </PreferenceCategory>
    <PreferenceCategory
        android:layout="@layout/category"
        android:title="@string/service_google_home"
        android:key="settings_category_google_home"/>
    <CheckBoxPreference
        android:icon="@drawable/ic_service_google_home"
        android:layout="@layout/preference_card"
        android:title="@string/service_google_home"
        android:key="settings_google_home_smartlight"
        android:summary="@string/service_google_home_limited"
        android:widgetLayout="@layout/preference_switch_widget"
        android:defaultValue="false"/>
    <Preference
        android:icon="@drawable/ic_action_accept"
        android:layout="@layout/preference"
        android:title="@string/select_devices"
        android:key="settings_google_home_smartlight_select"/>
    <com.urbandroid.sleep.gui.pref.LamerPreferenceCategory
        android:layout="@layout/category"
        android:title="@string/smartlight_all"
        android:key="settings_category_sl_hue"
        noTitle="1"
        show="1">
        <Preference
            android:icon="@drawable/ic_feature_smartlight"
            android:layout="@layout/preference_card"
            android:title="@string/smartlight_title"
            android:key="smartlight_hue"/>
        <Preference
            android:icon="@drawable/ic_experiment"
            android:layout="@layout/preference"
            android:title="Test"
            android:key="smartlight_test"/>
        <Preference
            android:icon="@drawable/ic_action_cancel"
            android:layout="@layout/preference"
            android:title="@string/turn_off"
            android:key="smartlight_off"/>
        <Preference
            android:icon="@drawable/ic_menu_down"
            android:layout="@layout/preference_more"
            android:title="Advance settings"/>
    </com.urbandroid.sleep.gui.pref.LamerPreferenceCategory>
    <com.urbandroid.sleep.gui.pref.LamerPreferenceCategory
        android:layout="@layout/category_help"
        android:title="@string/sleep_phaser"
        android:key="settings_category_sl_phaser"
        help="https://sleep.urbandroid.org/docs/devices/sleep_phaser.html"
        noTitle="1"
        show="1">
        <Preference
            android:icon="@drawable/ic_feature_sleepphaser"
            android:layout="@layout/preference_card"
            android:title="@string/smartlight_title"
            android:key="sleep_phaser_connect"
            android:defaultValue="false"/>
        <CheckBoxPreference
            android:icon="@drawable/ic_lightbulb"
            android:layout="@layout/preference"
            android:title="@string/settings_category_smartlight"
            android:key="smartlight_sleep_phaser_smartlight"
            android:widgetLayout="@layout/preference_switch_widget"
            android:defaultValue="false"/>
        <CheckBoxPreference
            android:icon="@drawable/ic_action_track"
            android:layout="@layout/preference"
            android:title="@string/settings_category_track"
            android:key="smartlight_sleep_phaser_sleep_tracking"
            android:widgetLayout="@layout/preference_switch_widget"
            android:defaultValue="false"/>
        <CheckBoxPreference
            android:icon="@drawable/ic_automagic"
            android:layout="@layout/preference"
            android:title="@string/auto_start_track_title"
            android:key="smartlight_sleep_phaser_auto_start"
            android:widgetLayout="@layout/preference_switch_widget"
            android:defaultValue="false"/>
        <Preference
            android:icon="@drawable/ic_puzzle"
            android:persistent="false"
            android:layout="@layout/preference"
            android:title="Purchase Sleep Phaser"
            android:key="sleep_phaser_purchase"/>
        <Preference
            android:icon="@drawable/ic_menu_down"
            android:layout="@layout/preference_more"
            android:title="Advance settings"/>
    </com.urbandroid.sleep.gui.pref.LamerPreferenceCategory>
    <com.urbandroid.sleep.gui.pref.LamerPreferenceCategory
        android:layout="@layout/category_help"
        android:title="@string/addons_mask_title"
        android:key="settings_category_sl_mask"
        help="https://sleep.urbandroid.org/docs/devices/sleep_mask.html"
        noTitle="1"
        show="1">
        <CheckBoxPreference
            android:icon="@drawable/ic_feature_sleepmask"
            android:layout="@layout/preference_card"
            android:title="@string/smartlight_mask"
            android:key="smartlight_mask_enabled"
            android:widgetLayout="@layout/preference_switch_widget"
            android:defaultValue="false"/>
        <Preference
            android:icon="@drawable/ic_bluetooth"
            android:layout="@layout/preference"
            android:title="@string/connect"
            android:key="sleep_mask_bt_connect"
            android:defaultValue="false"/>
        <CheckBoxPreference
            android:icon="@drawable/ic_action_track"
            android:layout="@layout/preference"
            android:title="@string/settings_category_track"
            android:key="smartlight_sleep_mask_sleep_tracking"
            android:widgetLayout="@layout/preference_switch_widget"
            android:defaultValue="false"/>
        <Preference
            android:icon="@drawable/ic_puzzle"
            android:persistent="false"
            android:layout="@layout/preference"
            android:title="Purchase Sleep Mask"
            android:key="smartlight_mask_purchase"/>
        <Preference
            android:icon="@drawable/ic_menu_down"
            android:layout="@layout/preference_more"
            android:title="Advance settings"/>
    </com.urbandroid.sleep.gui.pref.LamerPreferenceCategory>
    <PreferenceCategory
        android:layout="@layout/category"
        android:title="@string/settings_category_smartlight">
        <com.urbandroid.sleep.gui.SeekBarPreference
            android:icon="@drawable/ic_action_sun"
            android:layout="@layout/preference"
            android:max="100"
            android:title="@string/smartlight_max_intensity"
            android:key="smartlight_max_intensity"
            android:defaultValue="100"
            robobunny:interval="10"
            robobunny:min="10"
            robobunny:unitsLeft=""
            robobunny:unitsRight="%"/>
        <com.urbandroid.sleep.gui.MaterialDialogListPreference
            android:icon="@drawable/ic_pair"
            android:entries="@array/smartlight_peelight_time_entries"
            android:layout="@layout/preference"
            android:title="@string/smartlight_peelight"
            android:key="smartlight_peelight_time"
            android:defaultValue="-1"
            android:entryValues="@array/smartlight_peelight_time_values"/>
        <CheckBoxPreference
            android:icon="@drawable/ic_action_dream"
            android:layout="@layout/preference"
            android:title="@string/settings_category_lucid_title"
            android:key="smartlight_lucid_dreaming"
            android:widgetLayout="@layout/preference_switch_widget"
            android:defaultValue="false"/>
        <CheckBoxPreference
            android:icon="@drawable/ic_anti_snoring"
            android:layout="@layout/preference"
            android:title="@string/anti_snoring_title"
            android:key="smartlight_anti_snoring"
            android:widgetLayout="@layout/preference_switch_widget"
            android:defaultValue="false"/>
        <com.urbandroid.sleep.gui.MaterialDialogListPreference
            android:icon="@drawable/ic_alarm_x"
            android:entries="@array/smartlight_light_up_after_entries"
            android:layout="@layout/preference"
            android:title="@string/smartlight_light_up_after"
            android:key="smartlight_light_up_after"
            android:defaultValue="2"
            android:entryValues="@array/smartlight_light_up_after_values"/>
    </PreferenceCategory>
    <PreferenceCategory
        android:layout="@layout/category"
        android:title="@string/phone">
        <CheckBoxPreference
            android:icon="@drawable/ic_captcha_lightcaptcha"
            android:layout="@layout/preference_card"
            android:title="@string/sunrise"
            android:key="screenlight"
            android:summary="@string/screenlight"
            android:widgetLayout="@layout/preference_switch_widget"
            android:defaultValue="true"/>
        <CheckBoxPreference
            android:icon="@drawable/ic_feature_flashlight"
            android:layout="@layout/preference_card"
            android:title="@string/alarm_with_flashlight_title"
            android:key="alarm_with_flashlight"
            android:summary="@string/alarm_with_flashlight_summary"
            android:widgetLayout="@layout/preference_switch_widget"
            android:defaultValue="false"/>
    </PreferenceCategory>
    <Preference
        android:persistent="false"
        android:layout="@layout/preference"
        android:key="empty1"/>
    <Preference
        android:persistent="false"
        android:layout="@layout/preference"
        android:key="empty2"/>
</PreferenceScreen>
