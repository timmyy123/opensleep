<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/bg_charts"
    android:fitsSystemWindows="true"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:background="@color/transparent"
        app:elevation="0dp"
        app:layout_collapseMode="pin"
        app:layout_scrollFlags="enterAlways|scroll"
        style="@style/toolbar">
        <LinearLayout
            android:gravity="bottom"
            android:layout_gravity="end|center_vertical"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:layout_alignParentTop="true"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="16dp"
            android:layout_alignParentEnd="true">
            <androidx.appcompat.widget.AppCompatSpinner
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/filter"
                android:background="@drawable/card_search_chart"
                android:padding="8dp"
                android:layout_width="88dp"
                android:layout_height="wrap_content"
                android:popupBackground="@color/surface_variant"
                android:dropDownVerticalOffset="32dp"
                android:textAlignment="center"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="2dp"
                style="@style/Spinner"/>
            <androidx.appcompat.widget.AppCompatSpinner
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/period"
                android:background="@drawable/card_search_chart"
                android:padding="8dp"
                android:layout_width="88dp"
                android:layout_height="wrap_content"
                android:popupBackground="@color/surface_variant"
                android:dropDownVerticalOffset="32dp"
                android:textAlignment="center"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="4dp"
                style="@style/Spinner"/>
        </LinearLayout>
    </com.google.android.material.appbar.MaterialToolbar>
    <com.google.android.material.tabs.TabLayout
        android:gravity="center_horizontal"
        android:layout_gravity="center_horizontal"
        android:id="@+id/tabs"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        app:tabGravity="center"
        app:tabIndicator="@null"
        app:tabMinWidth="120dp"
        app:tabMode="scrollable"
        style="@style/MyCustomTabLayout"/>
    <RelativeLayout
        android:orientation="vertical"
        android:id="@+id/viewpager_parent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/toolbar">
        <com.urbandroid.sleep.gui.NoSwipeViewPager
            android:id="@+id/viewpager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/init_progress"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:layout_centerInParent="true"
            style="@style/Widget.Material3Expressive.CircularProgressIndicator.Wavy"/>
    </RelativeLayout>
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:layout_gravity="bottom"
        android:id="@+id/navigation"
        android:background="@drawable/card_search"
        android:visibility="gone"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_alignParentEnd="true"
        app:itemActiveIndicatorStyle="@style/MyNavigationViewActiveIndicator"
        app:itemHorizontalTranslationEnabled="false"
        app:itemIconTint="@color/primary"
        app:itemTextColor="@color/primary"
        app:labelVisibilityMode="unlabeled"
        app:menu="@menu/menu_chart_navigation"/>
</RelativeLayout>
