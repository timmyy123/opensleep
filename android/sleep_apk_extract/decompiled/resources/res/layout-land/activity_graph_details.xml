<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/graph_time_segments"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/root"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:background="@color/bg_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true">
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="horizontal"
                android:id="@+id/navigation"
                android:background="@color/bg_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/toolbar">
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <Button
                        android:layout_gravity="center"
                        android:id="@+id/prev"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:icon="@drawable/ic_arrow_back"
                        style="?attr/materialIconButtonFilledTonalStyle"/>
                </FrameLayout>
                <com.google.android.material.button.MaterialButton
                    android:textColor="@color/primary"
                    android:ellipsize="end"
                    android:layout_gravity="center"
                    android:id="@+id/title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:lines="1"
                    android:includeFontPadding="false"
                    android:layout_centerInParent="true"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    app:icon="@drawable/ic_menu_down"
                    app:iconGravity="end"
                    app:iconTint="@color/primary"
                    style="@style/Widget.MaterialComponents.Button.TextButton"/>
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <Button
                        android:layout_gravity="center"
                        android:id="@+id/next"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:icon="@drawable/ic_arrow_forth"
                        style="?attr/materialIconButtonFilledTonalStyle"/>
                </FrameLayout>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.appcompat.widget.Toolbar>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/graph_wrapper"
            android:background="@color/bg_card"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/toolbar"
            android:animateLayoutChanges="true"
            android:transitionName="box">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <ScrollView
                    android:gravity="center_horizontal"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/major_scroll_land"
                    android:scrollbars="none"
                    android:layout_width="136dp"
                    android:layout_height="wrap_content"
                    android:requiresFadingEdge="vertical">
                    <LinearLayout
                        android:gravity="center_horizontal"
                        android:layout_gravity="center_horizontal"
                        android:orientation="vertical"
                        android:id="@+id/major_measures"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </ScrollView>
                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1">
                    <RatingBar
                        android:id="@+id/sleep_rating_bar"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:numStars="5"
                        android:stepSize="0.25"
                        android:layout_alignParentTop="true"
                        android:layout_centerHorizontal="true"
                        android:elevation="8dp"
                        style="@style/RatingBar"/>
                    <com.urbandroid.sleep.graph.GraphView
                        android:id="@+id/sensor_graph"
                        android:background="@color/bg_card"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                    <com.urbandroid.sleep.graph.GraphView
                        android:id="@+id/noise_graph"
                        android:background="@color/bg_card"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                    <RelativeLayout
                        android:id="@+id/rating_graph"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        <com.urbandroid.sleep.graph.GraphView
                            android:id="@+id/graph"
                            android:visibility="gone"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"/>
                    </RelativeLayout>
                    <RelativeLayout
                        android:id="@+id/hypnogram_parent"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        <com.urbandroid.sleep.graph.GraphView
                            android:id="@+id/hypnogram"
                            android:visibility="gone"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"/>
                        <RelativeLayout
                            android:id="@+id/trial_layout"
                            android:visibility="gone"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <TextView
                                android:textColor="@color/secondary"
                                android:ellipsize="end"
                                android:id="@+id/trial_text"
                                android:padding="8dp"
                                android:visibility="gone"
                                android:layout_width="250dp"
                                android:layout_height="wrap_content"
                                android:text="@string/step_trial"
                                android:maxLines="3"
                                android:layout_above="@+id/trial_button"
                                android:layout_centerHorizontal="true"/>
                            <Button
                                android:id="@+id/trial_button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/trial_unlock"
                                android:drawableLeft="@drawable/ic_lock_unlock"
                                android:drawablePadding="4dp"
                                android:layout_centerInParent="true"/>
                        </RelativeLayout>
                    </RelativeLayout>
                </RelativeLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:background="@color/bg_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:animateLayoutChanges="true">
                <ViewStub
                    android:id="@+id/graph_toggle_chips_should_be_exclusive"
                    android:visibility="gone"
                    android:layout_width="0dp"
                    android:layout_height="0dp"/>
                <HorizontalScrollView
                    android:layout_gravity="center_horizontal"
                    android:background="@color/graph_time_segments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <com.google.android.material.chip.ChipGroup
                        android:orientation="horizontal"
                        android:id="@+id/bottom_toggle_graphs_bar"
                        android:paddingLeft="@dimen/preference_item_padding_side"
                        android:paddingRight="@dimen/preference_item_padding_side"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/preference_item_padding_side"
                        app:singleLine="true"/>
                </HorizontalScrollView>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:layout_gravity="center_vertical"
                    android:orientation="horizontal"
                    android:id="@+id/bottom_tag_bar"
                    android:background="@color/graph_time_segments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/graph_tag"
                        android:paddingLeft="16dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="@string/tag"
                        android:paddingStart="16dp"/>
                    <TextView
                        android:textColor="@color/secondary"
                        android:ellipsize="end"
                        android:id="@+id/graph_comment"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:maxLines="3"
                        android:minLines="1"
                        android:layout_weight="1"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:id="@+id/editAreaWrapper"
                    android:background="@color/graph_time_segments"
                    android:paddingBottom="8dp"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:requiresFadingEdge="horizontal">
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:layout_gravity="center_vertical"
                            android:orientation="horizontal"
                            android:id="@+id/tags"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </HorizontalScrollView>
                    <LinearLayout
                        android:orientation="vertical"
                        android:id="@+id/editArea"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <androidx.cardview.widget.CardView
                            android:id="@+id/toolbar_card"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="8dp"
                            android:layout_marginTop="4dp"
                            android:layout_marginRight="8dp"
                            app:cardBackgroundColor="@color/bg_search"
                            app:cardCornerRadius="@dimen/card_corner"
                            app:cardElevation="0dp">
                            <RelativeLayout
                                android:background="@drawable/card_outline_edit_solid"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">
                                <EditText
                                    android:textColor="@color/primary"
                                    android:id="@+id/sleep_rating_comment"
                                    android:background="@color/transparent"
                                    android:paddingLeft="16dp"
                                    android:paddingTop="12dp"
                                    android:paddingRight="32dp"
                                    android:paddingBottom="12dp"
                                    android:layout_width="match_parent"
                                    android:layout_height="64dp"
                                    android:hint="@string/rating_comment_label"
                                    android:maxLines="6"
                                    android:minLines="1"
                                    android:scrollHorizontally="true"
                                    android:layout_centerVertical="true"
                                    android:inputType="textCapSentences"
                                    android:imeOptions="actionDone"
                                    android:paddingStart="16dp"
                                    android:paddingEnd="32dp"/>
                                <ImageButton
                                    android:gravity="end|center_vertical"
                                    android:layout_gravity="end|center_vertical"
                                    android:id="@+id/fullscreen"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:layout_marginRight="16dp"
                                    android:src="@drawable/ic_action_full_screen"
                                    android:layout_alignParentRight="true"
                                    android:layout_centerVertical="true"
                                    android:layout_marginEnd="16dp"
                                    android:layout_alignParentEnd="true"
                                    android:elevation="2dp"
                                    style="@style/ButtonFlat"/>
                            </RelativeLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <RelativeLayout
                android:id="@+id/expand_collapse"
                android:background="@color/graph_time_segments"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <TextView
                    android:textAppearance="?android:attr/textAppearanceLarge"
                    android:textSize="32sp"
                    android:textColor="@color/tertiary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¯\\_(ツ)_/¯"
                    android:layout_centerInParent="true"/>
            </RelativeLayout>
        </LinearLayout>
        <ImageView
            android:id="@+id/slide_hint"
            android:visibility="gone"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/hint_slide_right"
            android:layout_centerInParent="true"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/add_button_before"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="-12dp"
            android:text="@string/add_record_title"
            android:includeFontPadding="false"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="-12dp"
            android:layout_alignParentStart="true"
            android:elevation="12dp"
            app:icon="@drawable/ic_arrow_back_white"
            app:iconPadding="2dp"
            style="@style/ExtendedFabNoMargin"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/add_button_after"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="-12dp"
            android:text="@string/add_record_title"
            android:includeFontPadding="false"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="-12dp"
            android:layout_alignParentEnd="true"
            android:elevation="12dp"
            app:icon="@drawable/ic_arrow_forth_white"
            app:iconGravity="end"
            app:iconPadding="2dp"
            style="@style/ExtendedFabNoMargin"/>
    </RelativeLayout>
    <com.google.android.material.button.MaterialButton
        android:layout_gravity="end|bottom"
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:includeFontPadding="false"
        android:elevation="6dp"
        app:elevation="6dp"
        app:icon="@drawable/ic_pencil"
        app:tint="@color/primary"
        style="@style/ExtendedFabIconOnly"/>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
