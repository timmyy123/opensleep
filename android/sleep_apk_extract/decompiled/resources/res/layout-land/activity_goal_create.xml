<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:background="@color/bg_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:background="@color/transparent"
        app:elevation="0dp"
        app:layout_collapseMode="pin"
        app:layout_scrollFlags="enterAlways|scroll"
        style="@style/toolbar"/>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:id="@+id/content"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginTop="16dp"
            android:layout_weight="1"
            android:layout_centerInParent="true">
            <ProgressBar
                android:id="@+id/goal_progress"
                android:background="@drawable/circle_bg_card"
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:max="100"
                android:progress="10"
                android:progressDrawable="@drawable/circular_progress"
                android:layout_centerInParent="true"
                style="?android:attr/progressBarStyleHorizontal"/>
            <EditText
                android:textSize="48sp"
                android:textColor="@color/tint"
                android:gravity="center"
                android:id="@+id/goal_target"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:singleLine="true"
                android:layout_centerInParent="true"/>
            <TextView
                android:textColor="@color/tint"
                android:id="@+id/goal_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toRightOf="@+id/goal_target"
                android:layout_alignBaseline="@+id/goal_target"
                android:layout_toEndOf="@+id/goal_target"/>
            <TextView
                android:textAppearance="?android:attr/textAppearanceLarge"
                android:gravity="center"
                android:id="@+id/goal_percent"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_above="@+id/goal_target"
                android:layout_centerInParent="true"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"/>
            <TextView
                android:id="@+id/goal_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/goal_target"
                android:layout_centerInParent="true"/>
            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@+id/goal_progress"
                android:layout_alignParentEnd="true">
                <com.google.android.material.chip.Chip
                    android:id="@+id/goal_plus"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text=" ＋ "
                    android:layout_centerInParent="true"
                    android:checkable="false"
                    android:textAlignment="center"
                    app:chipBackgroundColor="@color/bg_card"
                    app:chipMinTouchTargetSize="16dp"
                    app:chipStrokeColor="@color/bg_divider"
                    app:chipStrokeWidth="1dp"
                    style="@style/Material3CircleChip"/>
            </RelativeLayout>
            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@+id/goal_progress"
                android:layout_alignParentStart="true">
                <com.google.android.material.chip.Chip
                    android:gravity="center"
                    android:id="@+id/goal_minus"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text=" — "
                    android:layout_centerInParent="true"
                    android:textAlignment="center"
                    app:chipBackgroundColor="@color/bg_card"
                    app:chipMinTouchTargetSize="16dp"
                    app:chipStrokeColor="@color/bg_divider"
                    app:chipStrokeWidth="1dp"
                    style="@style/Material3CircleChip"/>
            </RelativeLayout>
        </RelativeLayout>
        <LinearLayout
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:id="@+id/list"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_above="@+id/buttons">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp">
                <TextView
                    android:textAppearance="?android:attr/textAppearanceLarge"
                    android:textColor="@color/primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/motivation"
                    android:layout_weight="1"/>
                <ImageButton
                    android:padding="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_help_q"
                    style="@style/ButtonFlat"/>
            </LinearLayout>
            <TextView
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="@color/primary"
                android:ellipsize="end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/goal_subscription_justification"
                android:lines="2"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"/>
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                app:cardCornerRadius="24dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:strokeColor="@android:color/transparent"
                app:strokeWidth="0dp">
                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/motivationGroup"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:backgroundTint="@color/bg_subtle"
                    app:tabBackground="@drawable/tab_selector"
                    app:tabGravity="fill"
                    app:tabIndicatorColor="@android:color/transparent"
                    app:tabIndicatorHeight="0dp"
                    app:tabMode="fixed"
                    app:tabRippleColor="@android:color/transparent"
                    app:tabSelectedTextColor="@color/white"
                    app:tabTextColor="@color/secondary">
                    <com.google.android.material.tabs.TabItem
                        android:icon="@drawable/ic_free"
                        android:id="@+id/goal_motivation_free"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <com.google.android.material.tabs.TabItem
                        android:icon="@drawable/ic_money"
                        android:id="@+id/goal_motivation_fee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <com.google.android.material.tabs.TabItem
                        android:icon="@drawable/ic_more_money"
                        android:id="@+id/goal_motivation_fee_high"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </com.google.android.material.tabs.TabLayout>
            </com.google.android.material.card.MaterialCardView>
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="horizontal"
                android:id="@+id/buttons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true">
                <com.google.android.material.button.MaterialButton
                    android:textSize="16sp"
                    android:textColor="@color/positive"
                    android:id="@+id/fab"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:focusable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/goal_new"
                    android:includeFontPadding="false"
                    android:paddingStart="36dp"
                    android:paddingEnd="36dp"
                    app:backgroundTint="@color/surface_variant"
                    app:icon="@drawable/ic_action_accept"
                    app:iconGravity="textStart"
                    app:iconTint="@color/positive"
                    style="@style/Widget.Material3.Button.TonalButton"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <TextView
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:textColor="@color/tint"
        android:id="@+id/goalFunnyName"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/toolbar"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>
    <ImageView
        android:id="@+id/goalFunnyImage"
        android:visibility="gone"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_alignParentEnd="true"/>
</RelativeLayout>
