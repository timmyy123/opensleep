<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/graph_time_segments"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/root"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:background="@color/bg_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/graph_wrapper"
                android:background="@color/bg_card"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:transitionName="box">
                <RelativeLayout
                    android:id="@+id/topGap"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="0dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/graph_edit_hint"
                        android:layout_centerInParent="true"
                        android:drawableStart="@drawable/hint_touch_dn"
                        style="@style/TextAppearance.AppCompat.Headline"/>
                </RelativeLayout>
                <com.urbandroid.sleep.graph.GraphView
                    android:id="@+id/graph"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>
                <com.urbandroid.sleep.graph.GraphView
                    android:id="@+id/hypnogram"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>
                <com.urbandroid.sleep.graph.GraphView
                    android:id="@+id/sensor_graph"
                    android:background="@color/bg_card"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>
                <com.urbandroid.sleep.graph.GraphView
                    android:id="@+id/noise_graph"
                    android:background="@color/bg_card"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>
                <RelativeLayout
                    android:id="@+id/bottomGap"
                    android:background="@color/graph_time_segments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <HorizontalScrollView
                        android:layout_gravity="center_horizontal"
                        android:background="@color/graph_time_segments"
                        android:scrollbars="none"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:requiresFadingEdge="horizontal">
                        <com.google.android.material.chip.ChipGroup
                            android:orientation="horizontal"
                            android:id="@+id/bottom_toggle_graphs_bar"
                            android:paddingLeft="@dimen/preference_item_padding_side"
                            android:paddingRight="@dimen/preference_item_padding_side"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="@dimen/preference_item_padding_side"
                            app:singleLine="true"/>
                    </HorizontalScrollView>
                </RelativeLayout>
            </LinearLayout>
            <ImageView
                android:id="@+id/slide_hint"
                android:visibility="gone"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@drawable/hint_slide_right"
                android:layout_centerInParent="true"/>
        </LinearLayout>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/add_button_before"
            android:padding="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="-12dp"
            android:text="@string/add_record_title"
            android:includeFontPadding="false"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="-12dp"
            android:layout_alignParentStart="true"
            android:elevation="12dp"
            app:icon="@drawable/ic_arrow_back_white"
            app:iconPadding="8dp"
            style="@style/ExtendedFabNoMargin"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/add_button_after"
            android:padding="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="-12dp"
            android:text="@string/add_record_title"
            android:includeFontPadding="false"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="-12dp"
            android:layout_alignParentEnd="true"
            android:elevation="12dp"
            app:icon="@drawable/ic_arrow_forth_white"
            app:iconGravity="end"
            app:iconPadding="8dp"
            style="@style/ExtendedFabNoMargin"/>
    </RelativeLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
