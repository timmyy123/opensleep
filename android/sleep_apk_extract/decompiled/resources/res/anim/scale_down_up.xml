<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android">
    <scale
        android:duration="160"
        android:pivotX="50%"
        android:pivotY="50%"
        android:repeatCount="1"
        android:repeatMode="reverse"
        android:fromXScale="1"
        android:toXScale="0"
        android:fromYScale="1"
        android:toYScale="0"/>
    <alpha
        android:duration="160"
        android:repeatCount="1"
        android:repeatMode="reverse"
        android:fromAlpha="1"
        android:toAlpha="0"/>
</set>
