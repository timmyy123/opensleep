<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <padding
                android:left="0dp"
                android:top="0dp"
                android:right="0dp"
                android:bottom="0dp"/>
            <solid android:color="@color/transparent"/>
        </shape>
    </item>
    <item>
        <shape>
            <padding
                android:left="0dp"
                android:top="0dp"
                android:right="0dp"
                android:bottom="1dp"/>
            <solid android:color="@color/shadow"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/bg_card"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</layer-list>
