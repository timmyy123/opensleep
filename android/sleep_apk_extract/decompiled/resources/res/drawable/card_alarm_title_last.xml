<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:top="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="0dp"
                android:topRightRadius="0dp"
                android:bottomLeftRadius="@dimen/card_corner"
                android:bottomRightRadius="@dimen/card_corner"/>
            <solid android:color="@color/bg_card"/>
        </shape>
    </item>
    <item
        android:top="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="0dp"
                android:topRightRadius="0dp"
                android:bottomLeftRadius="@dimen/card_corner"
                android:bottomRightRadius="@dimen/card_corner"/>
            <solid android:color="@color/card_outline"/>
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="0dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="0dp"
                android:topRightRadius="0dp"
                android:bottomLeftRadius="@dimen/card_corner"
                android:bottomRightRadius="@dimen/card_corner"/>
            <solid android:color="@color/bg_card"/>
        </shape>
    </item>
</layer-list>
