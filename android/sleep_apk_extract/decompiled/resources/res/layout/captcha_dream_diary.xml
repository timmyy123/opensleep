<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true">
    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-8dp"
        style="?android:attr/progressBarStyleHorizontal"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/add_record_layout"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="4dp">
        <CheckBox
            android:textColor="?android:attr/textColorTertiary"
            android:id="@+id/add_record_switch"
            android:paddingLeft="32dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12dp"
            android:text="@string/add_record_title"
            android:paddingStart="32dp"
            android:layout_marginStart="12dp"/> /&gt; 
        <SeekBar
            android:id="@+id/add_record_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="720"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <EditText
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:gravity="top"
                android:layout_gravity="top"
                android:id="@+id/text"
                android:background="@drawable/rect_edit_dark"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="16dp"
                android:hint="@string/dream_diary_hint"
                android:inputType="textMultiLine"/>
            <ImageButton
                android:id="@+id/tts"
                android:paddingTop="36dp"
                android:paddingBottom="36dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_action_mic_white"
                android:layout_alignParentRight="true"
                android:layout_alignParentBottom="true"
                android:paddingStart="36dp"
                android:paddingEnd="36dp"
                android:layout_alignParentEnd="true"
                style="@style/ButtonFlat"/>
        </RelativeLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:requiresFadingEdge="horizontal">
            <LinearLayout
                android:gravity="center_vertical"
                android:layout_gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/tags"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </HorizontalScrollView>
        <Button
            android:id="@+id/buttonOk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="100dp"
            android:text="@string/done"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="16dp"/>
    </LinearLayout>
</LinearLayout>
