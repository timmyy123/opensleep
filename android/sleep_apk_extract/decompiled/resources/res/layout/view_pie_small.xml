<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:layout_gravity="center_horizontal"
    android:layout_width="64dp"
    android:layout_height="80dp"
    android:layout_marginLeft="4dp"
    android:layout_marginStart="4dp">
    <com.urbandroid.sleep.gui.view.ProgressRingView
        android:id="@+id/pie_progress"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:animated="false"
        app:background_progress_color="@color/shade"
        app:corner_edges="true"
        app:progress="0.5"
        app:progress_color="@color/positive"
        app:ring_width="7dp"
        app:start_angle="150"
        app:sweep_angle_degree="242"/>
    <TextView
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:textColor="@color/white_tertiary"
        android:ellipsize="end"
        android:gravity="center_horizontal"
        android:id="@+id/pie_desc"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lines="1"
        android:includeFontPadding="false"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"/>
    <TextView
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:textSize="18sp"
        android:textColor="@color/primary"
        android:id="@+id/pie_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_below="@+id/pie_icon"
        android:layout_centerInParent="true"
        style="@style/pieTitle"/>
    <ImageView
        android:id="@+id/pie_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_centerHorizontal="true"
        android:layout_centerVertical="true"/>
    <TextView
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:textColor="@color/secondary"
        android:id="@+id/pie_value_second"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-4dp"
        android:layout_below="@+id/pie_value"
        android:layout_centerHorizontal="true"
        style="@style/pieTitle"/>
</RelativeLayout>
