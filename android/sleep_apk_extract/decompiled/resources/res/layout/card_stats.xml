<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="-4dp">
    <androidx.cardview.widget.CardView
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/foreground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/material_card_margin"
        android:layout_marginTop="@dimen/material_card_margin_half"
        android:layout_marginRight="@dimen/material_card_margin"
        android:layout_marginBottom="@dimen/material_card_padding"
        android:layout_marginStart="@dimen/material_card_margin"
        android:layout_marginEnd="@dimen/material_card_margin"
        android:transitionName="box"
        android:elevation="0dp"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="@dimen/card_corner"
        app:cardUseCompatPadding="false">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/card_corner_padding"
            android:paddingEnd="@dimen/card_corner_padding">
            <include
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                layout="@layout/card_stats_inside"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>
