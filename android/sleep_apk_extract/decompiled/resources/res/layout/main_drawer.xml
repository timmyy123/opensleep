<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:background="@color/bg_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:background="@color/bg_main"
        android:fitsSystemWindows="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:orientation="vertical"
            android:id="@+id/drawer_main"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <View
                android:layout_gravity="end|top"
                android:id="@+id/showcase_add_alarm"
                android:layout_width="48dp"
                android:layout_height="48dp"/>
            <com.google.android.material.appbar.AppBarLayout
                android:id="@+id/appbar"
                android:background="@null"
                android:fitsSystemWindows="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:elevation="0dp"
                android:stateListAnimator="@null"
                app:elevation="0dp"
                app:layout_behavior="com.urbandroid.sleep.fragment.dashboard.FixAppBarLayoutBehavior">
                <com.google.android.material.appbar.CollapsingToolbarLayout
                    android:id="@+id/ctoolbar"
                    android:background="@color/bg_main"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:elevation="0dp"
                    app:contentScrim="@color/bg_main"
                    app:elevation="0dp"
                    app:layout_scrollFlags="enterAlways|scroll"
                    app:statusBarScrim="@color/bg_main">
                    <androidx.appcompat.widget.Toolbar
                        android:layout_gravity="bottom"
                        android:id="@+id/toolbar"
                        android:background="@drawable/card_outline_search"
                        android:fitsSystemWindows="false"
                        android:layout_height="64dp"
                        android:layout_marginTop="@dimen/card_padding_horizontal_half"
                        android:layout_marginBottom="@dimen/card_padding_horizontal_half"
                        android:paddingEnd="4dp"
                        android:layout_marginStart="@dimen/card_padding_horizontal"
                        android:layout_marginEnd="@dimen/card_padding_horizontal"
                        style="@style/toolbar">
                        <TextView
                            android:textColor="@color/primary"
                            android:id="@+id/search_button"
                            android:text="@string/app_name_long"
                            style="@style/searchButtonMain"/>
                    </androidx.appcompat.widget.Toolbar>
                </com.google.android.material.appbar.CollapsingToolbarLayout>
                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tabs"
                    android:background="@color/bar"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:tabGravity="fill"
                    app:tabIndicator="@null"
                    app:tabMaxWidth="0dp"
                    app:tabMode="fixed"
                    style="@style/MyCustomTabLayout"/>
            </com.google.android.material.appbar.AppBarLayout>
            <com.urbandroid.sleep.gui.NoSwipeViewPager
                android:id="@+id/viewpager"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_behavior="@string/appbar_scrolling_view_behavior"/>
            <RelativeLayout
                android:layout_gravity="bottom"
                android:id="@+id/bottom_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/droid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="16dp"
                    android:layout_marginRight="16dp"
                    android:layout_alignParentLeft="true"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentStart="true"
                    android:elevation="4dp"/>
            </RelativeLayout>
            <LinearLayout
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:id="@+id/unlock_layout"
                android:background="@drawable/card_outline_special"
                android:padding="12dp"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:layout_behavior="@string/hide_bottom_view_on_scroll_behavior">
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <include
                        android:id="@+id/trial_layout"
                        android:visibility="gone"
                        layout="@layout/control_bar_unlock"/>
                    <RelativeLayout
                        android:id="@+id/adsStub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:gravity="center_horizontal"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </RelativeLayout>
                </LinearLayout>
            </LinearLayout>
            <com.google.android.material.button.MaterialButton
                android:layout_gravity="end|bottom"
                android:id="@+id/fab"
                android:text="@string/start_sleep_tracking"
                android:includeFontPadding="false"
                app:icon="@drawable/ic_action_track"
                style="@style/ExtendedFab"/>
            <com.google.android.material.bottomnavigation.BottomNavigationView
                android:layout_gravity="bottom"
                android:id="@+id/navigation"
                android:background="@drawable/card_search"
                android:fitsSystemWindows="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                app:elevation="0dp"
                app:itemActiveIndicatorStyle="@style/MyNavigationViewActiveIndicator"
                app:itemIconTint="@color/primary"
                app:itemTextColor="@color/primary"
                app:layout_behavior="@string/hide_bottom_view_on_scroll_behavior"
                app:menu="@menu/menu_main_navigation"/>
        </androidx.coordinatorlayout.widget.CoordinatorLayout>
        <View
            android:id="@+id/tint_cover_view"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_alignParentTop="true"/>
        <include
            android:id="@+id/activity_unlock"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:elevation="8dp"
            layout="@layout/activity_unlock"/>
        <View
            android:id="@+id/top_shade"
            android:background="@drawable/bg_grad_top"
            android:layout_width="match_parent"
            android:layout_height="@dimen/edge_to_edge_shade"
            android:layout_alignParentTop="true"/>
    </RelativeLayout>
    <com.urbandroid.sleep.gui.FixedNavigationView
        android:layout_gravity="start"
        android:id="@+id/left_drawer"
        android:background="@color/drawer"
        android:fitsSystemWindows="false"
        android:layout_width="wrap_content"
        android:layout_height="match_parent">
        <RelativeLayout
            android:id="@+id/drawer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="48dp">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/drawer_recycler"
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:cacheColorHint="@color/drawer"
                android:divider="@null"
                android:choiceMode="singleChoice"/>
        </RelativeLayout>
    </com.urbandroid.sleep.gui.FixedNavigationView>
</androidx.drawerlayout.widget.DrawerLayout>
