<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/separator"
        android:background="@color/quaternary"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@android:color/transparent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textColor="@color/tint"
            android:gravity="start|center_vertical"
            android:id="@android:id/title"
            android:tag="category"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginLeft="@dimen/menu_icon_padding"
            android:layout_marginRight="@dimen/menu_icon_padding"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/menu_icon_padding"
            android:layout_marginEnd="@dimen/menu_icon_padding"/>
        <ImageButton
            android:id="@+id/help"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_help_q"
            android:scaleType="fitCenter"
            android:layout_marginEnd="20dp"
            style="@style/ButtonFlat"/>
    </LinearLayout>
</LinearLayout>
