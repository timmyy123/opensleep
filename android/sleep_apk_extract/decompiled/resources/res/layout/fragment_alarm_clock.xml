<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/bg_main_legacy"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:id="@+id/bottom"
            android:padding="2dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12dp"
            android:layout_marginRight="12dp"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp">
            <com.urbandroid.sleep.alarmclock.DigitalClock
                android:id="@+id/clock"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                style="@style/ButtonFlat">
                <TextView
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="center_vertical"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/timeToBedDisplay"
                    android:padding="1dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawablePadding="4dp"
                    android:layout_alignParentLeft="true"
                    android:layout_alignParentStart="true"/>
            </com.urbandroid.sleep.alarmclock.DigitalClock>
            <Button
                android:id="@+id/sleep_button_fallback"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/start_sleep_tracking"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                style="@style/ButtonFlat"/>
        </RelativeLayout>
        <com.urbandroid.sleep.gui.NestedScrollingListView
            android:id="@+id/alarms_list"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:cacheColorHint="@android:color/transparent"
            android:divider="@null"
            android:layout_above="@+id/bottom"
            android:requiresFadingEdge="vertical"/>
    </RelativeLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/bedtime_indicator"
        android:paddingTop="12dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true"
        android:paddingStart="36dp"
        android:paddingEnd="36dp"
        android:layout_alignParentEnd="true">
        <ImageView
            android:id="@+id/bedtime_indicator_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginRight="8dp"
            android:layout_marginEnd="8dp"/>
        <TextView
            android:id="@+id/bedtime_indicator_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <com.google.android.material.button.MaterialButton
        android:textColor="@color/tertiary"
        android:id="@+id/no_data"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/add_alarm"
        android:includeFontPadding="false"
        android:layout_centerInParent="true"
        app:icon="@drawable/ic_alarm_plus"
        app:iconTint="@color/tertiary"
        style="@style/Widget.Material3.Button.OutlinedButton"/>
</RelativeLayout>
