<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:background="@color/bg_main"
        android:layout_width="match_parent"
        android:layout_height="@dimen/app_bar_height"
        app:elevation="0dp">
        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/ctoolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:collapsedTitleTextAppearance="@style/CollapsedToolbarStyle"
            app:elevation="0dp"
            app:expandedTitleTextAppearance="@style/FullWidthExpandedToolbarStyle"
            app:layout_scrollFlags="exitUntilCollapsed|scroll"
            app:statusBarScrim="@color/transparent">
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:background="@color/transparent"
                app:elevation="0dp"
                app:layout_collapseMode="pin"
                app:layout_scrollFlags="enterAlways|scroll"
                style="@style/toolbar"/>
        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="@dimen/card_padding_horizontal"
            android:paddingEnd="@dimen/card_padding_horizontal">
            <HorizontalScrollView
                android:layout_gravity="center_horizontal"
                android:scrollbars="none"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginRight="8dp"
                android:requiresFadingEdge="horizontal">
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/major_measures"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </HorizontalScrollView>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/bg_card_dashboard"
                app:cardCornerRadius="@dimen/card_corner"
                app:cardElevation="0dp">
                <RelativeLayout
                    android:background="@drawable/card_outline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:foreground="?android:attr/selectableItemBackground"
                    style="@style/SelectableItemBackground">
                    <RelativeLayout
                        android:paddingLeft="16dp"
                        android:paddingTop="16dp"
                        android:paddingRight="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">
                        <com.urbandroid.sleep.graph.GraphView
                            android:id="@+id/graph"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="128dp"/>
                        <Button
                            android:id="@+id/reveal"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="4dp"
                            android:text="@string/show_details"
                            android:layout_centerInParent="true"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp"/>
                        <ImageButton
                            android:id="@+id/graph_detail"
                            android:padding="4dp"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_action_full_screen_outline"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentEnd="true"
                            style="@style/ButtonFlat"/>
                    </RelativeLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>
            <LinearLayout
                android:gravity="center"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <com.urbandroid.sleep.graph.GraphView
                    android:id="@+id/hypnogram"
                    android:visibility="gone"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_marginTop="@dimen/card_padding_vertical"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/card_padding_horizontal"
                    android:layout_marginEnd="@dimen/card_padding_horizontal_half"/>
                <com.urbandroid.sleep.graph.GraphView
                    android:id="@+id/sensor_graph"
                    android:visibility="gone"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_marginTop="@dimen/card_padding_vertical"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/card_padding_horizontal_half"
                    android:layout_marginEnd="@dimen/card_padding_horizontal"/>
            </LinearLayout>
            <androidx.cardview.widget.CardView
                android:id="@+id/card_alarm"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_padding_vertical"
                android:elevation="0dp"
                app:cardBackgroundColor="@color/bg_card_dashboard"
                app:cardCornerRadius="@dimen/card_corner"
                app:cardElevation="0dp"
                app:elevation="0dp">
                <RelativeLayout
                    android:id="@+id/row_alarm"
                    android:background="@drawable/card_outline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:foreground="?android:attr/selectableItemBackground"
                    style="@style/SelectableItemBackground">
                    <RelativeLayout
                        android:id="@+id/box_alarm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/material_card_padding"
                            android:layout_marginBottom="@dimen/material_card_padding"
                            android:layout_marginStart="@dimen/card_corner_padding"
                            android:layout_marginEnd="@dimen/card_corner_padding">
                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">
                                <LinearLayout
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="36dp">
                                    <TextView
                                        android:textAppearance="?android:attr/textAppearanceMedium"
                                        android:textSize="14sp"
                                        android:textColor="@color/tint"
                                        android:ellipsize="end"
                                        android:gravity="start|top"
                                        android:layout_gravity="start|top"
                                        android:id="@+id/titleText"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="-2dp"
                                        android:text="@string/next_alarm"
                                        android:singleLine="true"
                                        android:layout_weight="1"
                                        android:textDirection="locale"
                                        android:textAlignment="gravity"/>
                                </LinearLayout>
                                <com.urbandroid.sleep.alarmclock.DigitalClock
                                    android:orientation="vertical"
                                    android:id="@+id/digitalClock"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content">
                                    <LinearLayout
                                        android:orientation="horizontal"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:baselineAligned="true">
                                        <ImageView
                                            android:id="@+id/next_alarm"
                                            android:visibility="gone"
                                            android:layout_width="2dp"
                                            android:layout_height="match_parent"
                                            android:layout_alignParentLeft="true"
                                            android:layout_alignParentStart="true"/>
                                        <TextView
                                            android:textSize="39sp"
                                            android:textStyle="normal"
                                            android:textColor="@color/primary"
                                            android:id="@+id/timeDisplay"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:baselineAligned="true"
                                            android:includeFontPadding="false"
                                            style="@style/MyTimeText"/>
                                        <TextView
                                            android:textAppearance="?android:attr/textAppearanceSmall"
                                            android:textColor="@color/primary"
                                            android:id="@+id/am_pm"
                                            android:paddingLeft="2dp"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:paddingStart="2dp"/>
                                        <ImageView
                                            android:gravity="center_vertical"
                                            android:layout_gravity="center_vertical"
                                            android:id="@+id/alarm_icon"
                                            android:paddingLeft="4dp"
                                            android:layout_width="wrap_content"
                                            android:layout_height="match_parent"
                                            android:paddingStart="4dp"/>
                                        <TextView
                                            android:textAppearance="?android:attr/textAppearanceSmall"
                                            android:textColor="@color/tertiary"
                                            android:ellipsize="end"
                                            android:id="@+id/label"
                                            android:paddingLeft="8dp"
                                            android:paddingRight="8dp"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:baselineAligned="true"
                                            android:singleLine="true"
                                            android:layout_weight="1"
                                            android:paddingStart="8dp"
                                            android:paddingEnd="8dp"/>
                                    </LinearLayout>
                                </com.urbandroid.sleep.alarmclock.DigitalClock>
                            </LinearLayout>
                            <com.google.android.material.button.MaterialButton
                                android:textAppearance="?android:attr/textAppearanceSmall"
                                android:textStyle="bold"
                                android:textColor="@color/negative"
                                android:id="@+id/alarm"
                                android:paddingTop="8dp"
                                android:paddingBottom="8dp"
                                android:visibility="visible"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/alarm_alert_dismiss_text"
                                android:includeFontPadding="false"
                                android:layout_alignParentBottom="true"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:layout_alignParentEnd="true"
                                android:elevation="0dp"
                                app:strokeColor="@color/negative"
                                app:strokeWidth="2dp"
                                app:tint="@color/negative"
                                style="@style/Widget.Material3.Button.OutlinedButton"/>
                        </RelativeLayout>
                    </RelativeLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@+id/weather"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/card_padding_vertical"
                app:cardBackgroundColor="@color/bg_card_dashboard"
                app:cardCornerRadius="@dimen/card_corner"
                app:cardElevation="0dp">
                <RelativeLayout
                    android:orientation="vertical"
                    android:background="@drawable/card_outline"
                    android:paddingTop="16dp"
                    android:paddingBottom="@dimen/material_card_padding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:paddingStart="@dimen/card_corner_padding"
                    android:paddingEnd="@dimen/card_corner_padding"
                    style="@style/SelectableItemBackgroundDark">
                    <TextView
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/tint"
                        android:ellipsize="end"
                        android:gravity="center_vertical"
                        android:layout_gravity="center_vertical"
                        android:id="@+id/weather1"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/weather"
                        android:singleLine="true"/>
                    <RelativeLayout
                        android:layout_gravity="center_vertical"
                        android:id="@+id/iconParent"
                        android:paddingRight="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/weather1"
                        android:paddingEnd="12dp">
                        <ImageView
                            android:layout_gravity="top"
                            android:id="@+id/weather_icon"
                            android:layout_width="56dp"
                            android:layout_height="56dp"/>
                    </RelativeLayout>
                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_gravity="center_vertical"
                        android:orientation="vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:layout_toRightOf="@+id/iconParent"
                        android:layout_below="@+id/weather1"
                        android:layout_centerInParent="true"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp">
                        <TextView
                            android:id="@+id/weather_temp"
                            android:visibility="gone"
                            android:fadingEdge="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:includeFontPadding="false"
                            style="@style/TextAppearance.Material3.HeadlineMedium"/>
                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/weather_temp">
                            <TextView
                                android:textAppearance="?android:attr/textAppearanceSmall"
                                android:textColor="@color/primary"
                                android:gravity="center_vertical"
                                android:layout_gravity="center_vertical"
                                android:id="@+id/weather_condition"
                                android:visibility="visible"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawablePadding="8dp"
                                android:paddingEnd="8dp"/>
                            <TextView
                                android:textAppearance="?android:attr/textAppearanceSmall"
                                android:textColor="@color/primary"
                                android:gravity="center_vertical"
                                android:layout_gravity="center_vertical"
                                android:id="@+id/weather_cc"
                                android:visibility="gone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawablePadding="8dp"
                                android:paddingEnd="8dp"/>
                            <TextView
                                android:textAppearance="?android:attr/textAppearanceSmall"
                                android:textColor="@color/primary"
                                android:gravity="center_vertical"
                                android:layout_gravity="center_vertical"
                                android:id="@+id/weather_ws"
                                android:visibility="gone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawableLeft="@drawable/ic_cloud"
                                android:drawablePadding="8dp"
                                android:paddingEnd="8dp"/>
                            <TextView
                                android:textAppearance="?android:attr/textAppearanceSmall"
                                android:textColor="@color/primary"
                                android:gravity="center_vertical"
                                android:layout_gravity="center_vertical"
                                android:id="@+id/weather_sun"
                                android:visibility="gone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawablePadding="8dp"
                                android:paddingEnd="8dp"/>
                        </androidx.appcompat.widget.LinearLayoutCompat>
                    </androidx.appcompat.widget.LinearLayoutCompat>
                    <TextView
                        android:textSize="10sp"
                        android:id="@+id/weather_affiliation"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_alignParentEnd="true"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@+id/foreground"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="64dp"
                app:cardBackgroundColor="@color/bg_card_dashboard"
                app:cardCornerRadius="@dimen/card_corner"
                app:cardElevation="0dp">
                <androidx.appcompat.widget.LinearLayoutCompat
                    android:orientation="vertical"
                    android:background="@drawable/card_outline"
                    android:paddingTop="16dp"
                    android:paddingBottom="@dimen/material_card_padding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:paddingStart="@dimen/card_corner_padding"
                    android:paddingEnd="@dimen/card_corner_padding"
                    style="@style/SelectableItemBackgroundDark">
                    <RatingBar
                        android:layout_gravity="center_horizontal"
                        android:id="@+id/sleep_rating_bar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:numStars="5"
                        android:stepSize="0.25"
                        android:layout_alignParentTop="true"
                        android:layout_centerHorizontal="true"
                        style="@style/RatingBar"/>
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:requiresFadingEdge="horizontal">
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:layout_gravity="center_vertical"
                            android:orientation="horizontal"
                            android:id="@+id/tags"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </HorizontalScrollView>
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/sleep_rating_comment_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/rating_comment_label"
                        app:boxBackgroundColor="@color/bg_main"
                        app:boxCornerRadiusBottomEnd="@dimen/card_corner"
                        app:boxCornerRadiusBottomStart="@dimen/card_corner"
                        app:boxCornerRadiusTopEnd="@dimen/card_corner"
                        app:boxCornerRadiusTopStart="@dimen/card_corner"
                        app:boxStrokeWidth="0dp"
                        app:endIconDrawable="@drawable/ic_action_mic"
                        app:endIconMode="custom"
                        style="?attr/textInputOutlinedStyle">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/sleep_rating_comment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="8dp"
                            android:hint="@string/rating_comment_label"
                            android:maxLines="3"
                            android:minLines="1"
                            android:inputType="textMultiLine"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </androidx.appcompat.widget.LinearLayoutCompat>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:layout_gravity="end|bottom"
        android:id="@+id/done"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/fab_padding"
        android:src="@drawable/ic_action_accept"/>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
