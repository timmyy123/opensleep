<?xml version="1.0" encoding="utf-8"?>
<com.google.android.gms.ads.formats.UnifiedNativeAdView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/native_ad"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:textSize="14sp"
            android:textColor="@color/white"
            android:background="@drawable/rect_ad"
            android:paddingLeft="2dp"
            android:paddingTop="0dp"
            android:paddingRight="2dp"
            android:paddingBottom="0dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/material_card_padding"
            android:layout_marginTop="2dp"
            android:layout_marginRight="@dimen/material_card_padding"
            android:text="Ad"
            android:includeFontPadding="false"
            android:layout_alignParentTop="true"/>
        <RelativeLayout
            android:layout_gravity="center"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="@dimen/material_card_padding"
            android:layout_marginTop="28dp"
            android:layout_marginRight="@dimen/material_card_padding"
            android:layout_marginBottom="@dimen/material_card_margin_half"
            android:layout_marginStart="@dimen/material_card_padding"
            android:layout_marginEnd="@dimen/material_card_padding">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="@dimen/material_card_margin"
                android:layout_above="@+id/controls">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:layout_gravity="center_vertical"
                    android:orientation="horizontal"
                    android:id="@+id/ad_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:gravity="center_vertical"
                        android:layout_gravity="center_vertical"
                        android:id="@+id/nativead_app_icon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginRight="8dp"
                        android:adjustViewBounds="true"
                        android:layout_marginEnd="8dp"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textAppearance="?android:attr/textAppearanceMedium"
                            android:textColor="@color/white"
                            android:ellipsize="end"
                            android:id="@+id/nativead_headline"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:lines="1"/>
                        <RatingBar
                            android:id="@+id/nativead_stars"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:numStars="5"
                            android:stepSize="0.5"
                            android:isIndicator="true"
                            style="?android:attr/ratingBarStyleSmall"/>
                    </LinearLayout>
                </LinearLayout>
                <TextView
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:textColor="@color/white"
                    android:ellipsize="end"
                    android:id="@+id/nativead_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:maxLines="3"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:paddingTop="@dimen/material_card_margin"
                    android:paddingBottom="@dimen/material_card_margin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <com.google.android.gms.ads.formats.MediaView
                        android:id="@+id/nativead_media"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                    <ImageView
                        android:id="@+id/nativead_image"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="0dp"
                        android:layout_marginRight="0dp"
                        android:scaleType="centerCrop"/>
                </LinearLayout>
            </LinearLayout>
            <Button
                android:textSize="18sp"
                android:textColor="@color/white"
                android:id="@+id/dismiss"
                android:padding="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/close"
                android:drawableLeft="@drawable/ic_action_cancel_white"
                android:drawablePadding="4dp"
                android:layout_alignParentLeft="true"
                android:layout_alignParentBottom="true"
                android:drawableStart="@drawable/ic_action_cancel_white"
                android:layout_alignParentStart="true"
                style="@style/ButtonFlatMediumText"/>
            <LinearLayout
                android:gravity="bottom"
                android:layout_gravity="end|bottom"
                android:orientation="vertical"
                android:id="@+id/controls"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="-2dp"
                android:layout_alignParentRight="true"
                android:layout_alignParentBottom="true"
                android:layout_marginEnd="-2dp"
                android:layout_alignParentEnd="true">
                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/white"
                    android:gravity="center_horizontal"
                    android:id="@+id/nativead_store"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:textColor="@color/white"
                    android:gravity="center_horizontal"
                    android:id="@+id/nativead_price"
                    android:padding="4dp"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <Button
                    android:textSize="18sp"
                    android:gravity="center_vertical"
                    android:id="@+id/nativead_call_to_action"
                    android:padding="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/ButtonsleepGreen"/>
            </LinearLayout>
        </RelativeLayout>
    </RelativeLayout>
</com.google.android.gms.ads.formats.UnifiedNativeAdView>
