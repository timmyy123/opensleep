<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/foreground"
    android:layout_width="match_parent"
    android:layout_height="196dp"
    android:layout_marginBottom="8dp"
    android:layout_marginEnd="8dp"
    app:cardBackgroundColor="@color/bg_card_dashboard"
    app:cardCornerRadius="@dimen/card_corner"
    app:cardElevation="0dp">
    <RelativeLayout
        android:background="@drawable/card_outline"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:foreground="?android:attr/selectableItemBackground"
        style="@style/SelectableItemBackgroundDark">
        <RelativeLayout
            android:gravity="end"
            android:layout_gravity="end"
            android:id="@+id/iconParent"
            android:layout_width="144dp"
            android:layout_height="144dp"
            android:layout_marginBottom="-16dp"
            android:layout_alignParentBottom="true"
            android:layout_marginEnd="-16dp"
            android:layout_alignParentEnd="true">
            <ImageView
                android:id="@+id/icon_bg"
                android:layout_width="144dp"
                android:layout_height="144dp"
                android:src="@drawable/circle_bg_accent2"
                android:layout_centerInParent="true"
                android:alpha="0.3"/>
            <ImageView
                android:id="@android:id/icon"
                android:layout_width="144dp"
                android:layout_height="144dp"
                android:layout_centerInParent="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:paddingTop="16dp"
            android:paddingBottom="@dimen/material_card_padding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:foreground="?android:attr/selectableItemBackground"
            android:paddingStart="@dimen/card_corner_padding"
            android:paddingEnd="@dimen/card_corner_padding"
            style="@style/SelectableItemBackgroundDark">
            <TextView
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:textColor="?android:attr/textColorPrimary"
                android:id="@android:id/title"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_alignParentStart="true"/>
            <TextView
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:ellipsize="end"
                android:id="@android:id/summary"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:layout_below="@android:id/title"
                android:layout_alignParentStart="true"/>
        </RelativeLayout>
    </RelativeLayout>
</androidx.cardview.widget.CardView>
