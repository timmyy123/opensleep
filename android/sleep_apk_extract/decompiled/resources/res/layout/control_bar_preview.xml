<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/controlBar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.google.android.material.button.MaterialButton
        android:textSize="19sp"
        android:textColor="@color/white"
        android:id="@+id/next"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/next"
        android:includeFontPadding="false"
        android:shadowColor="@color/shadow"
        android:shadowRadius="24"
        android:layout_alignParentBottom="true"
        android:paddingStart="32dp"
        android:paddingEnd="16dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_alignParentEnd="true"
        app:backgroundTint="@color/shadow"
        app:icon="@drawable/ic_next"
        app:iconGravity="textEnd"
        app:iconSize="32dp"
        app:iconTint="@color/white"
        app:strokeColor="@color/white"
        app:strokeWidth="1dp"
        style="@style/Widget.Material3Expressive.Button.OutlinedButton"/>
    <com.google.android.material.button.MaterialButton
        android:textSize="16sp"
        android:textColor="@color/white"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:id="@+id/skip"
        android:padding="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="180dp"
        android:text="@string/skip"
        android:maxLines="2"
        android:includeFontPadding="false"
        android:shadowColor="@color/shadow"
        android:shadowRadius="24"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_alignParentStart="true"
        app:icon="@drawable/ic_action_cancel"
        app:iconGravity="textStart"
        app:iconSize="18dp"
        app:iconTint="@color/white"
        style="@style/Widget.Material3Expressive.Button.TextButton"/>
    <com.google.android.material.button.MaterialButton
        android:textSize="19sp"
        android:textColor="@color/white"
        android:ellipsize="end"
        android:id="@+id/done"
        android:padding="16dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:text="@string/done"
        android:lines="1"
        android:includeFontPadding="false"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        app:icon="@drawable/ic_action_accept"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconTint="@color/white"
        app:strokeColor="@color/white"
        app:strokeWidth="1dp"
        style="@style/Widget.Material3Expressive.Button.OutlinedButton"/>
</RelativeLayout>
