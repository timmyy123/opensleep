<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="96dp"
    android:layout_height="128dp"
    android:layout_margin="4dp">
    <com.urbandroid.sleep.gui.view.ProgressRingView
        android:id="@+id/pie_progress"
        android:layout_width="100dp"
        android:layout_height="100dp"
        app:animated="true"
        app:animation_duration="800"
        app:background_progress_color="@color/white_quaternary"
        app:corner_edges="true"
        app:progress="0.5"
        app:progress_color="@color/positive"
        app:ring_width="7dp"
        app:start_angle="150"
        app:sweep_angle_degree="242"/>
    <TextView
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:textColor="@color/white"
        android:ellipsize="end"
        android:gravity="center_horizontal"
        android:id="@+id/pie_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:lines="1"
        android:layout_below="@+id/center"
        android:layout_centerHorizontal="true"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        style="@style/pieTitle"/>
    <TextView
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:textSize="19sp"
        android:textColor="@color/white"
        android:id="@+id/pie_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:includeFontPadding="false"
        android:layout_above="@+id/pie_desc"
        android:layout_centerHorizontal="true"
        style="@style/pieTitle"/>
    <View
        android:id="@+id/center_above"
        android:background="@color/transparent"
        android:layout_width="100dp"
        android:layout_height="16dp"
        android:layout_centerInParent="true"/>
    <View
        android:id="@+id/center"
        android:background="@color/transparent"
        android:layout_width="100dp"
        android:layout_height="4dp"
        android:layout_below="@+id/center_above"/>
    <ImageView
        android:id="@+id/pie_icon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_above="@+id/pie_value"
        android:layout_centerHorizontal="true"/>
    <TextView
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:textColor="@color/white_tertiary"
        android:id="@+id/pie_value_second"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:includeFontPadding="false"
        android:layout_below="@+id/pie_desc"
        android:layout_centerHorizontal="true"/>
</RelativeLayout>
