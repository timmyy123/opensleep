<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/parent"
    android:background="@drawable/widget_background_normal"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:requiresFadingEdge="horizontal">
    <ImageView
        android:id="@+id/graph"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scaleType="fitXY"
        android:maxHeight="120dp"
        android:layout_above="@+id/from"
        android:layout_below="@+id/titleParent"/>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/titleParent"
        android:background="@drawable/widget_background_fab_inner"
        android:padding="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:layout_centerHorizontal="true">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/img1"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="4dp"/>
            <TextView
                android:textSize="18sp"
                android:textColor="@color/primary"
                android:ellipsize="end"
                android:id="@+id/title1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_history_records"
                android:lines="1"
                android:fontFamily="@font/product"
                android:paddingEnd="8dp"/>
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/img2"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="4dp"/>
            <TextView
                android:textSize="18sp"
                android:textColor="@color/primary"
                android:ellipsize="end"
                android:id="@+id/title2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lines="1"
                android:fontFamily="@font/product"
                android:paddingEnd="8dp"/>
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/img5"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="4dp"/>
            <TextView
                android:textSize="18sp"
                android:textColor="@color/primary"
                android:ellipsize="end"
                android:id="@+id/title5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lines="1"
                android:fontFamily="@font/product"
                android:paddingEnd="8dp"/>
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/img7"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="4dp"/>
            <TextView
                android:textSize="18sp"
                android:textColor="@color/primary"
                android:ellipsize="end"
                android:id="@+id/title7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lines="1"
                android:fontFamily="@font/product"
                android:paddingEnd="8dp"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/title_second"
            android:paddingBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/title"
            android:layout_centerHorizontal="true"
            android:paddingStart="2dp"
            android:paddingEnd="2dp">
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/img3"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="4dp"/>
            <TextView
                android:textSize="18sp"
                android:textColor="@color/primary"
                android:ellipsize="end"
                android:id="@+id/title3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lines="1"
                android:fontFamily="@font/product"
                android:paddingEnd="8dp"/>
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/img4"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="4dp"/>
            <TextView
                android:textSize="18sp"
                android:textColor="@color/primary"
                android:ellipsize="end"
                android:id="@+id/title4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lines="1"
                android:fontFamily="@font/product"
                android:paddingEnd="8dp"/>
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/img6"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="4dp"/>
            <TextView
                android:textSize="18sp"
                android:textColor="@color/primary"
                android:ellipsize="end"
                android:id="@+id/title6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lines="1"
                android:fontFamily="@font/product"
                android:paddingEnd="8dp"/>
        </LinearLayout>
    </LinearLayout>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/primary"
        android:id="@+id/from"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="12dp"
        android:includeFontPadding="false"
        android:layout_alignParentBottom="true"
        android:fontFamily="sans-serif-condensed-medium"
        android:layout_marginStart="10dp"
        android:layout_alignParentStart="true"/>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/primary"
        android:id="@+id/to"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="12dp"
        android:includeFontPadding="false"
        android:layout_alignParentBottom="true"
        android:fontFamily="sans-serif-condensed-medium"
        android:layout_marginEnd="10dp"
        android:layout_alignParentEnd="true"/>
</RelativeLayout>
