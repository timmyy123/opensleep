<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="204dp">
    <RelativeLayout
        android:id="@+id/background"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/hide_card_compatibility_margin">
        <LinearLayout xmlns:app="http://schemas.android.com/apk/res-auto"
            android:id="@+id/cardBackground"
            android:background="@drawable/card_outline_solid_pageable"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/material_card_margin_half"
            android:elevation="0dp">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/transition_parent"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <RelativeLayout
                    android:id="@+id/paddingBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/material_card_padding"
                        android:layout_marginBottom="@dimen/material_card_padding"
                        android:layout_toLeftOf="@+id/imageBackground"
                        android:layout_alignParentLeft="true"
                        android:layout_marginStart="@dimen/card_corner_padding"
                        android:layout_toStartOf="@+id/imageBackground"
                        android:layout_alignParentStart="true">
                        <TextView
                            android:textColor="@color/secondary"
                            android:id="@+id/titleBackground"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/menu_about"
                            style="@style/cardTitle"/>
                        <TextView
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:textColor="@color/tertiary"
                            android:ellipsize="end"
                            android:id="@+id/summaryBackground"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/tutorial_summary"
                            android:maxLines="5"/>
                    </LinearLayout>
                    <ImageView
                        android:id="@+id/imageBackground"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:layout_width="180dp"
                        android:layout_height="180dp"
                        android:layout_margin="8dp"
                        android:src="@drawable/preview_empty"
                        android:scaleType="fitCenter"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true"/>
                </RelativeLayout>
                <LinearLayout
                    android:layout_gravity="center_vertical"
                    android:orientation="horizontal"
                    android:id="@+id/graph_layout_background"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>
        <View
            android:background="@drawable/bg_shade"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignLeft="@+id/cardBackground"
            android:layout_alignTop="@+id/cardBackground"
            android:layout_alignRight="@+id/cardBackground"
            android:layout_alignBottom="@+id/cardBackground"
            android:layout_alignStart="@+id/cardBackground"
            android:layout_alignEnd="@+id/cardBackground"
            android:elevation="0dp"/>
    </RelativeLayout>
    <include
        android:id="@+id/backgroundHide"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignLeft="@+id/foreground"
        android:layout_alignTop="@+id/foreground"
        android:layout_alignRight="@+id/foreground"
        android:layout_alignBottom="@+id/foreground"
        android:layout_alignStart="@+id/foreground"
        android:layout_alignEnd="@+id/foreground"
        layout="@layout/card_hide_background"/>
    <androidx.cardview.widget.CardView
        android:id="@+id/foreground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginLeft="@dimen/material_card_margin_half"
        android:layout_marginTop="@dimen/material_card_margin_half"
        android:layout_marginRight="@dimen/material_card_margin"
        android:layout_marginBottom="@dimen/material_card_margin_half"
        android:layout_marginStart="@dimen/material_card_margin_half"
        android:layout_marginEnd="@dimen/material_card_margin"
        app:cardBackgroundColor="@color/t1"
        app:cardCornerRadius="@dimen/card_corner">
        <RelativeLayout
            android:background="?android:attr/selectableItemBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:foreground="?android:attr/selectableItemBackground"
            style="@style/SelectableItemBackgroundDark">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <ImageView
                    android:id="@+id/image"
                    android:padding="2dp"
                    android:layout_width="168dp"
                    android:layout_height="168dp"
                    android:src="@drawable/preview_track"
                    android:scaleType="fitCenter"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/material_card_padding"
                    android:layout_marginStart="@dimen/card_corner_padding"
                    android:layout_marginEnd="144dp">
                    <TextView
                        android:textColor="@color/white"
                        android:id="@+id/title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/menu_about"
                        style="@style/cardTitle"/>
                    <TextView
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="@color/white_secondary"
                        android:ellipsize="end"
                        android:id="@+id/summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/tutorial_summary"
                        android:maxLines="5"
                        android:requiresFadingEdge="vertical"/>
                </LinearLayout>
            </RelativeLayout>
            <TextView
                android:textColor="@color/white"
                android:gravity="center_horizontal"
                android:id="@+id/slideHint"
                android:padding="2dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/next"
                android:drawableTop="@drawable/hint_slide_left"
                android:drawablePadding="-8dp"
                android:layout_alignParentRight="true"
                android:layout_alignParentBottom="true"/>
            <TextView
                android:textColor="@color/white"
                android:gravity="center_horizontal"
                android:id="@+id/tapHint"
                android:padding="2dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_tap"
                android:drawableTop="@drawable/hint_touch_long_press"
                android:drawablePadding="-4dp"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"/>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>
