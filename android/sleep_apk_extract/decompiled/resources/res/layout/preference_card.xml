<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:paddingTop="@dimen/card_padding_horizontal_half"
    android:paddingBottom="@dimen/card_padding_horizontal_half"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="?android:attr/listPreferredItemHeight"
    android:paddingStart="@dimen/card_padding_horizontal"
    android:paddingEnd="@dimen/card_padding_horizontal">
    <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/foreground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/bg_card_dashboard"
        app:cardCornerRadius="@dimen/card_corner"
        app:cardElevation="0dp">
        <RelativeLayout
            android:id="@+id/highlight_parent"
            android:background="@drawable/card_outline"
            android:paddingTop="16dp"
            android:paddingBottom="@dimen/material_card_padding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:foreground="?android:attr/selectableItemBackground"
            android:paddingStart="@dimen/card_corner_padding"
            android:paddingEnd="@dimen/card_corner_padding"
            style="@style/SelectableItemBackgroundDark">
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <RelativeLayout
                    android:id="@+id/iconParent"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginTop="4dp"
                    android:layout_centerInParent="true"
                    android:layout_marginEnd="12dp">
                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/circle_accent"
                        android:layout_centerInParent="true"
                        android:alpha="0.75"/>
                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/circle_bg_accent"
                        android:layout_centerInParent="true"/>
                    <ImageView
                        android:id="@android:id/icon"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_centerInParent="true"/>
                </RelativeLayout>
                <RelativeLayout
                    android:layout_gravity="center_vertical"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">
                    <TextView
                        android:textSize="19sp"
                        android:ellipsize="marquee"
                        android:id="@android:id/title"
                        android:paddingRight="5dp"
                        android:fadingEdge="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:includeFontPadding="false"
                        android:layout_alignParentLeft="true"
                        android:layout_alignParentTop="true"
                        android:paddingEnd="5dp"
                        android:layout_alignParentStart="true"
                        style="@style/prefTitle"/>
                    <TextView
                        android:textColor="?android:attr/textColorSecondary"
                        android:id="@android:id/summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxLines="6"
                        android:layout_below="@android:id/title"
                        android:layout_alignLeft="@android:id/title"
                        android:layout_alignStart="@android:id/title"/>
                </RelativeLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@android:id/widget_frame"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:layout_alignTop="@android:id/title"
                    android:layout_alignParentEnd="true"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
