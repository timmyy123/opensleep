<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:fitsSystemWindows="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/volume_indicator"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="-6dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true">
        <ImageView
            android:layout_gravity="center_horizontal"
            android:id="@+id/volume_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_volume_off_small_trans_white"/>
        <ProgressBar
            android:id="@+id/volume_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            android:indeterminate="true"
            style="@style/ProgressBarsleep"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_horizontal"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:layout_centerInParent="true">
        <TextView
            android:textAppearance="?android:attr/textAppearanceLarge"
            android:textColor="@color/white_tertiary"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/alertTitle"
            android:padding="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"/>
        <ImageView style="@style/ndivw_dark"/>
        <com.urbandroid.sleep.alarmclock.DigitalClock
            android:gravity="center_horizontal"
            android:paddingTop="4dp"
            android:paddingBottom="6dp"
            android:baselineAligned="true"
            style="@style/clock">
            <TextView
                android:textSize="62sp"
                android:textStyle="normal"
                android:textColor="@color/white"
                android:id="@+id/timeDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/MyTimeText"/>
            <TextView
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:textColor="@color/white"
                android:id="@+id/am_pm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <SurfaceView
                android:id="@+id/camera_preview"
                android:layout_width="1dp"
                android:layout_height="1dp"/>
        </com.urbandroid.sleep.alarmclock.DigitalClock>
        <com.urbandroid.sleep.gui.SquareLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minWidth="140dp"
            android:minHeight="140dp">
            <Button
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:id="@+id/snooze"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:minHeight="140dp"
                android:text="@string/alarm_alert_snooze_text"
                android:layout_weight="1"
                style="@style/ButtonsleepGreen"/>
            <Button
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:ellipsize="end"
                android:id="@+id/dismiss"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:minHeight="140dp"
                android:text="@string/alarm_alert_dismiss_text"
                android:singleLine="true"
                android:layout_weight="1"
                style="@style/ButtonsleepRed"/>
        </com.urbandroid.sleep.gui.SquareLayout>
        <HorizontalScrollView
            android:scrollbarSize="2dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:requiresFadingEdge="horizontal">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/snooze_options"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </HorizontalScrollView>
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="10sp"
                android:ellipsize="end"
                android:id="@+id/palaceholdeDoNotDelete"
                android:padding="6dp"
                android:visibility="invisible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="480dp"
                android:minWidth="260dp"
                android:text="                                                                                                      "
                android:singleLine="true"/>
        </RelativeLayout>
    </LinearLayout>
</RelativeLayout>
