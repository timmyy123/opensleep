<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:elevation="0dp"
        app:elevation="0dp"
        app:title="@string/smartwatch"
        style="@style/toolbar"/>
    <ImageView
        android:id="@+id/icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_alignParentStart="true"/>
    <TextView
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:id="@+id/selected_wearable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:layout_above="@+id/progress"
        android:layout_centerHorizontal="true"/>
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progress"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="32dp"
        android:layout_toRightOf="@+id/icon"
        android:layout_centerVertical="true"
        android:layout_marginEnd="32dp"
        android:layout_toEndOf="@+id/icon"
        style="@style/Widget.Material3Expressive.LinearProgressIndicator.Wavy"/>
    <TextView
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:id="@+id/message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/message_connectivity_wait"
        android:layout_below="@+id/progress"
        android:layout_centerHorizontal="true"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/instructions"
        android:background="@drawable/card_outline"
        android:padding="16dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_below="@+id/message"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp">
        <TextView
            android:textColor="@color/primary"
            android:id="@+id/instruction_title"
            android:padding="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/advice_caution"
            android:drawablePadding="8dp"
            android:drawableStart="@drawable/ic_achievement_info"/>
        <TextView
            android:textColor="@color/primary"
            android:id="@+id/instruction"
            android:padding="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <com.google.android.material.button.MaterialButton
            android:ellipsize="end"
            android:layout_gravity="end"
            android:id="@+id/instruction_button"
            android:focusable="false"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:text="@string/install_button"
            android:singleLine="true"
            android:includeFontPadding="false"
            android:textAllCaps="true"
            app:icon="@drawable/ic_download_plain"
            style="@style/Widget.Material3.Button.TextButton"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/buttons"
        android:background="@drawable/card_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:layout_alignParentBottom="true">
        <com.google.android.material.button.MaterialButton
            android:textSize="16sp"
            android:textColor="@color/primary"
            android:ellipsize="end"
            android:id="@+id/button_cancel"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/cancel"
            android:singleLine="true"
            android:includeFontPadding="false"
            android:layout_weight="1"
            app:icon="@drawable/ic_action_cancel"
            app:iconGravity="textStart"
            app:iconTint="@color/primary"
            style="@style/Widget.Material3.Button.TextButton"/>
        <com.google.android.material.button.MaterialButton
            android:textSize="16sp"
            android:textColor="@color/primary"
            android:ellipsize="end"
            android:id="@+id/button_track_without"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/no_smartwatch"
            android:singleLine="true"
            android:includeFontPadding="false"
            android:layout_weight="1"
            app:icon="@drawable/ic_action_watch_off"
            app:iconGravity="textStart"
            app:iconTint="@color/primary"
            style="@style/Widget.Material3.Button.TextButton"/>
    </LinearLayout>
</RelativeLayout>
