<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/foreground"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="@dimen/material_card_margin"
    android:layout_marginTop="@dimen/material_card_margin_half"
    android:layout_marginRight="@dimen/material_card_margin"
    android:layout_marginBottom="@dimen/material_card_margin_half"
    android:foreground="?attr/selectableItemBackgroundBorderless"
    app:cardBackgroundColor="@color/bg_card_dashboard"
    app:cardCornerRadius="@dimen/card_corner"
    app:cardElevation="0dp">
    <RelativeLayout
        android:orientation="vertical"
        android:id="@+id/root"
        android:background="@drawable/card_outline"
        android:padding="0dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:foreground="?android:attr/selectableItemBackground"
        style="@style/SelectableItemBackgroundDark">
        <TextView
            android:textColor="@color/primary"
            android:ellipsize="end"
            android:layout_gravity="start"
            android:id="@+id/day"
            android:paddingLeft="@dimen/card_corner_padding"
            android:paddingTop="12dp"
            android:paddingRight="@dimen/card_corner_padding"
            android:paddingBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lines="1"
            style="@style/cardTitle"/>
        <TextView
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="@color/secondary"
            android:ellipsize="end"
            android:id="@+id/title_secondary"
            android:paddingLeft="@dimen/card_corner_padding"
            android:paddingTop="12dp"
            android:paddingRight="@dimen/card_corner_padding"
            android:paddingBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stats_caption_others"
            android:lines="1"
            android:layout_alignParentEnd="true"/>
        <HorizontalScrollView
            android:id="@+id/scroll"
            android:scrollbars="none"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_below="@+id/day"
            android:layout_centerHorizontal="true"
            android:requiresFadingEdge="horizontal">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/pies"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"/>
        </HorizontalScrollView>
    </RelativeLayout>
</androidx.cardview.widget.CardView>
