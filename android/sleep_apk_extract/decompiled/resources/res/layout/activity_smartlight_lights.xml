<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/linear1"
    android:fitsSystemWindows="true"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:layout_gravity="center"
        android:id="@+id/progress"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:layout_centerInParent="true"
        style="@style/Widget.Material3Expressive.CircularProgressIndicator.Wavy"/>
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_alignParentTop="true"
        android:elevation="0dp"
        app:elevation="0dp"
        style="@style/toolbar"/>
    <ListView
        android:id="@+id/lights_list"
        android:scrollbars="none"
        android:fadingEdge="none"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:cacheColorHint="@android:color/transparent"
        android:divider="@null"
        android:layout_above="@+id/bottom_bar"
        android:layout_below="@+id/toolbar"
        android:requiresFadingEdge="vertical"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/empty_list_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true">
        <TextView
            android:textColor="@color/tertiary"
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:text="@string/smartlight_no_devices"/>
        <Button
            android:layout_gravity="center_horizontal"
            android:id="@+id/find_new_bridge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/smartlight_find_bridge"/>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/bottom_bar"
        android:background="@color/bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true">
        <Button
            android:textStyle="bold"
            android:id="@+id/buttonOk"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_ok"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
</RelativeLayout>
