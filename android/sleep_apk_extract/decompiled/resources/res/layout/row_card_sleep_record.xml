<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/foreground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/material_card_margin"
        android:layout_marginBottom="@dimen/material_card_margin"
        android:layout_marginStart="@dimen/material_card_margin"
        android:layout_marginEnd="@dimen/material_card_margin"
        app:cardBackgroundColor="@color/bg_card_dashboard"
        app:cardCornerRadius="@dimen/card_corner"
        app:cardElevation="0dp">
        <RelativeLayout
            android:background="@drawable/card_outline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:foreground="?android:attr/selectableItemBackground"
            style="@style/SelectableItemBackground">
            <RelativeLayout
                android:paddingLeft="16dp"
                android:paddingTop="16dp"
                android:paddingRight="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <com.urbandroid.sleep.graph.GraphView
                    android:id="@+id/row_graph"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginTop="72dp"
                    android:transitionName="box"/>
                <TextView
                    android:textColor="@color/primary"
                    android:ellipsize="end"
                    android:id="@+id/titleTextGraph"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:layout_alignParentLeft="true"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentStart="true"
                    style="@style/cardTitle"/>
                <TextView
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="@color/secondary"
                    android:ellipsize="end"
                    android:id="@+id/row_graph_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:singleLine="true"
                    android:layout_below="@+id/titleTextGraph"/>
                <ImageView
                    android:id="@+id/row_graph_tags"
                    android:paddingTop="2dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentRight="true"
                    android:layout_alignParentEnd="true"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/secondary"
                    android:id="@+id/star"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableRight="@drawable/ic_star_small_secondary"
                    android:drawablePadding="1dp"
                    android:layout_toLeftOf="@+id/row_graph_tags"
                    android:layout_alignParentTop="true"
                    android:drawableEnd="@drawable/ic_star_small_secondary"
                    android:layout_toStartOf="@+id/row_graph_tags"/>
            </RelativeLayout>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>
