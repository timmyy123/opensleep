<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <include
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignLeft="@+id/foreground"
        android:layout_alignTop="@+id/foreground"
        android:layout_alignRight="@+id/foreground"
        android:layout_alignBottom="@+id/foreground"
        android:layout_alignStart="@+id/foreground"
        android:layout_alignEnd="@+id/foreground"
        layout="@layout/card_hide_background"/>
    <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/foreground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/material_card_margin_half"
        android:layout_marginBottom="@dimen/material_card_margin_half"
        android:layout_marginStart="@dimen/material_card_margin_half"
        android:layout_marginEnd="@dimen/material_card_margin_half"
        app:cardBackgroundColor="@color/bg_card_dashboard"
        app:cardCornerRadius="@dimen/card_corner"
        app:cardElevation="0dp">
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/card_outline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:foreground="?android:attr/selectableItemBackground"
            style="@style/SelectableItemBackground">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textColor="@color/primary"
                    android:ellipsize="end"
                    android:id="@+id/title"
                    android:paddingTop="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sleep_phases"
                    android:singleLine="true"
                    android:layout_alignParentLeft="true"
                    android:layout_alignParentTop="true"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_alignParentStart="true"
                    style="@style/cardTitle"/>
                <LinearLayout
                    android:layout_gravity="bottom"
                    android:orientation="horizontal"
                    android:paddingTop="4dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/graph_parent"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">
                    <TextView
                        android:ellipsize="start"
                        android:gravity="end"
                        android:id="@+id/sleep_awake"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Awake 10%"
                        android:lines="1"
                        android:layout_weight="1"
                        android:layout_marginStart="24dp"/>
                </LinearLayout>
            </LinearLayout>
            <RelativeLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <com.urbandroid.sleep.graph.GraphView
                    android:id="@+id/row_graph"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"/>
                <ImageView
                    android:id="@+id/tags"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/percentage"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/graph_parent"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView
                    android:ellipsize="end"
                    android:id="@+id/sleep_deep"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:lines="1"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-condensed-medium"/>
                <TextView
                    android:ellipsize="end"
                    android:gravity="center"
                    android:id="@+id/sleep_rem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="~REM 10%"
                    android:lines="1"
                    android:fontFamily="sans-serif-condensed-medium"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"/>
                <TextView
                    android:ellipsize="end"
                    android:gravity="end"
                    android:id="@+id/sleep_light"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Light 10%"
                    android:lines="1"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-condensed-medium"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>
