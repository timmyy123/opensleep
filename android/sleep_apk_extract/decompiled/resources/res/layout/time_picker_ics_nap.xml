<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/layout_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <include layout="@layout/time_picker_addon_controls_alarm"/>
    <FrameLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/alarm_wheels"
        android:background="@color/tint_dark"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <FrameLayout
        android:gravity="center_horizontal"
        android:layout_gravity="center_horizontal"
        android:id="@+id/nap_wheels"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true">
        <android.widget.NumberPicker
            android:theme="@style/NumberPickerText"
            android:gravity="center_horizontal"
            android:layout_gravity="center_horizontal"
            android:id="@+id/nap_wheel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </FrameLayout>
    <LinearLayout
        android:gravity="center_horizontal"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:id="@+id/alarm_controls"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true">
        <ImageButton
            android:id="@+id/sunrise"
            android:padding="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_action_sunrise"
            style="@style/ButtonFlat"/>
        <ImageButton
            android:textSize="14sp"
            android:ellipsize="end"
            android:id="@+id/scheduleIdealAlarm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/schedule_ideal"
            android:singleLine="true"
            style="@style/ButtonFlat"/>
        <ImageButton
            android:id="@+id/fullscreen"
            android:padding="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_action_mic"
            style="@style/ButtonFlat"/>
        <EditText
            android:id="@+id/time_edit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:maxLength="4"/>
    </LinearLayout>
    <include
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        layout="@layout/time_picker_bottom_bar"/>
</LinearLayout>
