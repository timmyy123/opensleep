<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:gravity="center_horizontal"
        android:id="@+id/descriptionTextview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:text="@string/smartlight_hue_press_pushlink_button"
        android:layout_below="@+id/imagePushlink"/>
    <ImageView
        android:id="@+id/imagePushlink"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_action_bridge_pushlink"
        android:layout_centerInParent="true"
        android:contentDescription="@string/smartlight_hue_press_pushlink_button"/>
    <ProgressBar
        android:id="@+id/countdownPB"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="30"
        android:layout_below="@+id/descriptionTextview"
        android:layout_alignStart="@+id/descriptionTextview"
        android:layout_alignEnd="@+id/descriptionTextview"
        style="?android:attr/progressBarStyleHorizontal"/>
</RelativeLayout>
