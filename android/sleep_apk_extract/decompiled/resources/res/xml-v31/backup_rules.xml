<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="false">
        <include
            domain="sharedpref"
            path="."/>
        <include
            domain="database"
            path="."/>
    </cloud-backup>
    <device-transfer>
        <include
            domain="sharedpref"
            path="."/>
        <include
            domain="database"
            path="."/>
        <include
            domain="file"
            path="."/>
    </device-transfer>
</data-extraction-rules>
