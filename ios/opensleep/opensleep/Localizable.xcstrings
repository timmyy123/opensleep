  "strings" : {
    "%@ / %@" : {
      "comment" : "A label displaying the current download progress in terms of file size. The first argument is the string “%.2f GB”, the string “%.1f MB” or the string “%.1f KB”. The second argument is the string “%.2f GB”, the string “%.1f MB” or the string “%.1f KB”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ / %2$@"
          }
        }
      }
    },
    "%lld tokens" : {
      "comment" : "A label displaying the current context window size in tokens. The value is automatically updated as the user slides the slider.",
      "isCommentAutoGenerated" : true
    },
    "%lldh %lldm" : {
      "comment" : "A label displaying the total sleep duration in hours and minutes. The first argument is the number of hours. The second argument is the number of minutes.",
